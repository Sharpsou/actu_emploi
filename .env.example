APP_NAME=Actu Emploi
APP_ENV=development
APP_VERSION=0.1.0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/actu_emploi
PUBLIC_BASE_URL=http://localhost:3000
PYTHON_EXECUTABLE=
ACTU_EMPLOI_USE_FIXTURES=0
ENABLE_FRANCE_TRAVAIL=1
ENABLE_JOOBLE=0
PUBLIC_REQUEST_TIMEOUT_SECONDS=20
PUBLIC_REQUEST_DELAY_SECONDS=2.0
PUBLIC_MAX_JOBS_PER_ROLE=4
PUBLIC_MAX_REQUESTS_PER_SOURCE=30
PUBLIC_CACHE_TTL_SECONDS=21600
FRANCE_TRAVAIL_SEARCH_RADIUS_KM=10
FRANCE_TRAVAIL_SEARCH_SORT=0
DEFAULT_SEARCH_LOCATION=44109
DEFAULT_SEARCH_LOCATION_LABEL=Nantes
FRANCE_TRAVAIL_SEARCH_URL=https://candidat.francetravail.fr/offres/recherche
JOOBLE_API_KEY=
JOOBLE_SEARCH_URL=https://fr.jooble.org/emploi-{role_slug}/{location_slug}
LIGHTWEIGHT_LLM_ENABLED=0
LIGHTWEIGHT_LLM_DEVICE=auto
LIGHTWEIGHT_LLM_ENDPOINT_URL=http://localhost:11434/v1/chat/completions
LIGHTWEIGHT_LLM_AMD_ENDPOINT_URL=
LIGHTWEIGHT_LLM_MODEL=qwen2.5:3b
LIGHTWEIGHT_LLM_TIMEOUT_SECONDS=20
LIGHTWEIGHT_LLM_KEEP_ALIVE=30s
